{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/vite-env.d.ts",
    "src/routes/**/*.ts",
    "src/routes/**/*.tsx",
    "src/pages/**/*.ts",
    "src/pages/**/*.tsx",
    "src/provider/AppProviders.tsx",
    "src/provider/ThemeProvider.tsx",
    "src/provider/ReCaptchaProvider.tsx",
    "src/lib/**/*.ts",
    "src/lib/**/*.tsx",
    "src/hooks/useAuthSync.ts",
    "src/hooks/useMediaQuery.ts",
    "src/apis/**/*.ts",
    "src/apis/**/*.tsx",
    "src/stores/**/*.ts",
    "src/stores/**/*.tsx",
    "src/types/**/*.ts",
    "src/types/**/*.tsx",
    "src/components/GoogleAnalytics.tsx",
    "src/components/atoms/Logo.tsx",
    "src/components/atoms/ProfileDropdown.tsx",
    "src/components/atoms/k/FloatingDock.tsx",
    "src/components/molecules/HeaderSection.tsx",
    "src/components/molecules/StatCard.tsx",
    "src/components/organisms/FooterSection.tsx",
    "src/components/organisms/AboutSection.tsx",
    "src/components/organisms/ContactSection.tsx",
    "src/components/organisms/FeaturesSectionHome.tsx",
    "src/components/organisms/FeedbackSection.tsx",
    "src/components/organisms/HeroSection.tsx",
    "src/components/organisms/PendingJobDialog.tsx",
    "src/components/organisms/PricingSection.tsx",
    "src/components/organisms/StackSection.tsx",
    "src/components/organisms/auth/signin-form.tsx",
    "src/components/organisms/auth/signup-form.tsx",
    "src/components/organisms/auth/role-selection.tsx",
    "src/components/organisms/k/SideBar.tsx",
    "src/components/ui/accordion.tsx",
    "src/components/ui/alert-dialog.tsx",
    "src/components/ui/animated-group.tsx",
    "src/components/ui/avatar.tsx",
    "src/components/ui/button.tsx",
    "src/components/ui/card.tsx",
    "src/components/ui/dialog.tsx",
    "src/components/ui/drawer.tsx",
    "src/components/ui/dropdown-menu.tsx",
    "src/components/ui/input-otp.tsx",
    "src/components/ui/input.tsx",
    "src/components/ui/label.tsx",
    "src/components/ui/particles.tsx",
    "src/components/ui/retro-grid.tsx",
    "src/components/ui/skeleton.tsx",
    "src/components/ui/toast.tsx",
    "src/components/ui/tooltip.tsx",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "src/app/**", "src/middleware.ts"]
}
